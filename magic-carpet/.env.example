# 复制此文件为 .env.local 并填入真实值（.env.local 不要提交到 Git）

# Anthropic Claude API Key
# 申请地址: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# 火山引擎 TTS
# 申请地址: https://console.volcengine.com/speech/service/8
VOLC_APPID=你的AppID
VOLC_ACCESS_TOKEN=你的AccessToken

# 声音选择（可选，不填默认灿灿）
# zh_female_cancan_mars_bigtts  — 灿灿·温柔女声（推荐）
# zh_female_yangtian_moon_bigtts — 扬天·清澈女声
# zh_male_qingcang_mars_bigtts  — 擎苍·深沉男声
VOLC_VOICE=zh_female_cancan_mars_bigtts

# 反馈箱 → GitHub Issue（应用内「✎ 反馈」提交后自动在你的仓库开 Issue）
# GITHUB_TOKEN 需有 Issues 写权限：
#   - Fine-grained token：对目标仓库授予 Issues = Read and write
#   - 或经典 token：勾选 repo
# 申请地址: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# 目标仓库，格式 owner/repo
GITHUB_REPO=TimNiegml/magic-carpet
# 可选：Issue 标签，逗号分隔，默认 feedback
GITHUB_ISSUE_LABELS=feedback
